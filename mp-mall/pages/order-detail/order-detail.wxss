.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Status Banner */
.status-banner {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  color: #fff;
}

.status-orange { background: linear-gradient(135deg, #fa8c16, #f5222d); }
.status-blue { background: linear-gradient(135deg, #1890ff, #096dd9); }
.status-green { background: linear-gradient(135deg, #52c41a, #389e0d); }
.status-gray { background: linear-gradient(135deg, #999, #666); }

.status-icon { font-size: 48rpx; margin-right: 20rpx; }

.status-text { display: flex; flex-direction: column; }
.status-title { font-size: 34rpx; font-weight: bold; }
.status-desc { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; }

/* Card */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 30rpx;
}

.card-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding-bottom: 20rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* Address */
.address-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.address-top { display: flex; align-items: center; gap: 20rpx; }
.address-name { font-size: 30rpx; font-weight: bold; }
.address-phone { font-size: 26rpx; color: #666; }
.address-detail { font-size: 26rpx; color: #999; }

/* Order Items */
.order-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child { border-bottom: none; }

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.item-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.item-name { font-size: 26rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-specs { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.item-bottom { display: flex; justify-content: space-between; align-items: center; }
.item-price { font-size: 28rpx; color: #ff4d4f; font-weight: bold; }
.item-qty { font-size: 24rpx; color: #999; }

/* Amount */
.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
}

.amount-row.total {
  border-top: 1rpx solid #f5f5f5;
  margin-top: 8rpx;
  padding-top: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.discount { color: #52c41a; }
.total-price { color: #ff4d4f; font-size: 32rpx; }

/* Order Info */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14rpx 0;
  font-size: 24rpx;
}

.info-label { color: #999; width: 140rpx; flex-shrink: 0; }
.info-value-row { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 12rpx; }
.info-value { color: #666; text-align: right; word-break: break-all; }
.copy-btn { font-size: 22rpx; color: #1890ff; border: 1rpx solid #1890ff; border-radius: 6rpx; padding: 2rpx 12rpx; flex-shrink: 0; }

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}
