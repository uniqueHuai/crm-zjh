<view wx:if="{{loading}}" class="loading">加载中...</view>

<view wx:else class="page">
  <view class="status-banner status-{{orderStatusType}}">
    <text class="status-icon">{{orderStatusText}}</text>
    <view class="status-text">
      <text class="status-title">{{orderStatusText}}</text>
      <text class="status-desc" wx:if="{{order.status === 'pending'}}">请尽快完成支付，以免订单失效</text>
      <text class="status-desc" wx:elif="{{order.status === 'paid'}}">商家正在备货，请耐心等待</text>
      <text class="status-desc" wx:elif="{{order.status === 'shipped'}}">商品配送中，请留意签收</text>
    </view>
  </view>

  <view class="card address-card" wx:if="{{order.addressName}}">
    <view class="address-top">
      <text class="address-name">{{order.addressName}}</text>
      <text class="address-phone">{{order.addressPhone}}</text>
    </view>
    <text class="address-detail">{{order.addressDetail}}</text>
  </view>

  <view class="card">
    <view class="card-header">商品信息</view>
    <view class="order-item" wx:for="{{orderItems}}" wx:key="id">
      <image class="item-img" src="{{item.productImage || '/images/default-product.png'}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-name">{{item.productName || item.name}}</text>
        <text class="item-specs" wx:if="{{item.skuSpecs}}">{{item.skuSpecs}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price || item.unitPrice}}</text>
          <text class="item-qty">x{{item.quantity || 1}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">费用明细</view>
    <view class="amount-row">
      <text>商品金额</text>
      <text>¥{{formattedAmount}}</text>
    </view>
    <view class="amount-row" wx:if="{{order.discountAmount > 0}}">
      <text>优惠金额</text>
      <text class="discount">-¥{{formattedDiscount}}</text>
    </view>
    <view class="amount-row" wx:if="{{order.shippingFee > 0}}">
      <text>运费</text>
      <text>¥{{formattedShipping}}</text>
    </view>
    <view class="amount-row total">
      <text>实付金额</text>
      <text class="total-price">¥{{formattedPayAmount}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-header">订单信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <view class="info-value-row">
        <text class="info-value">{{order.orderNo || order.id}}</text>
        <text class="copy-btn" bindtap="copyText" data-text="{{order.orderNo || order.id}}">复制</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{order.createdAt}}">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createdAt}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text class="info-label">付款时间</text>
      <text class="info-value">{{order.payTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.shipTime}}">
      <text class="info-label">发货时间</text>
      <text class="info-value">{{order.shipTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">买家备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <view class="action-bar" wx:if="{{order.status === 'pending'}}">
    <button class="action-btn secondary" bindtap="cancelOrder">取消订单</button>
    <button class="action-btn primary" bindtap="payOrder">立即支付</button>
  </view>

  <view class="action-bar" wx:elif="{{order.status === 'shipped'}}">
    <button class="action-btn primary" bindtap="confirmOrder">确认收货</button>
  </view>
</view>
