.page {
  padding-bottom: 120rpx;
}

.product-swiper {
  height: 600rpx;
}

.product-img {
  width: 100%;
  height: 600rpx;
  background: #f0f0f0;
}

.info-section {
  padding: 30rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 16rpx;
}

.product-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.sku-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.sku-row:last-child {
  border-bottom: none;
}

.sku-label {
  flex: 1;
  font-size: 26rpx;
}

.stock {
  font-size: 22rpx;
  color: #999;
  margin-left: 20rpx;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  font-size: 32rpx;
}

.qty-value {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  height: 100rpx;
}

.bar-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
}

.cart-btn {
  background: #ff7a45;
}

.buy-btn {
  background: #ff4d4f;
}
