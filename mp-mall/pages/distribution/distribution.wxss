.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.profile-section {
  background: linear-gradient(135deg, #722ed1, #531dab);
  padding: 40rpx 30rpx;
  color: #fff;
}

.summary-row {
  display: flex;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-num {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #722ed1;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 35%;
  right: 35%;
  height: 4rpx;
  background: #722ed1;
  border-radius: 2rpx;
}

.empty {
  padding: 80rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.member-list {
  padding: 16rpx;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.member-name {
  font-size: 28rpx;
}

.member-time {
  font-size: 22rpx;
  color: #999;
}

.commission-list {
  padding: 16rpx;
}

.commission-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.commission-info {
  display: flex;
  flex-direction: column;
}

.commission-order {
  font-size: 26rpx;
}

.commission-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.commission-right {
  text-align: right;
}

.commission-amount {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
  display: block;
}

.commission-status {
  font-size: 22rpx;
  margin-top: 4rpx;
  display: block;
}

.commission-status.pending { color: #faad14; }
.commission-status.settled { color: #52c41a; }
.commission-status.cancelled { color: #999; }

.bind-section {
  padding: 30rpx;
}

.bind-btn {
  background: #722ed1;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
