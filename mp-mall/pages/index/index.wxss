.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-placeholder {
  display: block;
  background: #f5f5f5;
  border-radius: 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.notice-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff8e1;
  color: #f57c00;
  font-size: 24rpx;
  border-bottom: 1rpx solid #ffecb3;
}

.notice-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.notice-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scroll-view {
  flex: 1;
}

.banner {
  height: 320rpx;
}

.banner-img {
  width: 100%;
  height: 320rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-bottom: 10rpx;
}

.category-icon-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  padding: 20rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.activity-scroll {
  white-space: nowrap;
  padding-bottom: 20rpx;
}

.activity-card {
  display: inline-block;
  width: 280rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #ff4d4f, #ff7a45);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  color: #fff;
}

.activity-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.activity-type {
  font-size: 22rpx;
  opacity: 0.8;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  padding-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 320rpx;
  background: #f0f0f0;
}

.product-name {
  display: block;
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price-row {
  padding: 0 20rpx;
}

.price {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: bold;
}

.ad-section {
  padding: 0;
}

.ad-image {
  width: 100%;
  display: block;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
