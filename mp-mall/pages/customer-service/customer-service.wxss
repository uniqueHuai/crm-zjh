.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 16px;
  overflow-y: scroll;
}

.message-item {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}

.message-item.right {
  flex-direction: row-reverse;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 10px;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.bubble {
  max-width: 70%;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 15px;
  line-height: 1.5;
  word-break: break-word;
}

.bubble.assistant {
  background: #ffffff;
  color: #333;
  border: 1px solid #eee;
  border-top-left-radius: 4px;
}

.bubble.user {
  background: #4361ee;
  color: #ffffff;
  border-top-right-radius: 4px;
}

.bubble.loading text {
  animation: blink 1.5s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.quick-questions {
  padding: 12px 16px;
  background: #fff;
  border-top: 1px solid #eee;
}

.quick-title {
  font-size: 13px;
  color: #999;
  margin-bottom: 8px;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.quick-item {
  background: #f0f2ff;
  color: #4361ee;
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 13px;
  border: 1px solid #dde0ff;
}

.input-area {
  padding: 10px 16px;
  background: #fff;
  border-top: 1px solid #eee;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 10px;
}

.input {
  flex: 1;
  height: 40px;
  padding: 0 14px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 15px;
}

.send-btn {
  padding: 8px 20px;
  background: #ccc;
  color: #fff;
  border-radius: 20px;
  font-size: 14px;
  flex-shrink: 0;
}

.send-btn.active {
  background: #4361ee;
}
