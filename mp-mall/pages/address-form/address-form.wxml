<view class="page">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">收件人</text>
      <input class="form-input" placeholder="请输入收件人姓名" value="{{form.name}}" data-field="name" bindinput="onFieldChange" />
    </view>

    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{form.phone}}" data-field="phone" bindinput="onFieldChange" />
    </view>

    <view class="form-row">
      <view class="form-item flex-1">
        <text class="form-label">省份</text>
        <input class="form-input" placeholder="省份" value="{{form.province}}" data-field="province" bindinput="onFieldChange" />
      </view>
      <view class="form-item flex-1">
        <text class="form-label">城市</text>
        <input class="form-input" placeholder="城市" value="{{form.city}}" data-field="city" bindinput="onFieldChange" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">区/县</text>
      <input class="form-input" placeholder="区/县（选填）" value="{{form.district}}" data-field="district" bindinput="onFieldChange" />
    </view>

    <view class="form-item">
      <text class="form-label">详细地址</text>
      <textarea class="form-textarea" placeholder="街道、门牌号等" value="{{form.address}}" data-field="address" bindinput="onFieldChange"></textarea>
    </view>

    <view class="form-item switch-row">
      <text class="form-label">设为默认地址</text>
      <switch checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#1890ff" />
    </view>
  </view>

  <view class="btn-area">
    <button class="btn-primary" bindtap="handleSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存地址'}}
    </button>
  </view>
</view>
