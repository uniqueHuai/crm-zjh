<view class="page">
  <view class="page-header">确认订单</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <scroll-view wx:else class="content" scroll-y>
    <view class="section address-section" bindtap="selectAddress">
      <view wx:if="{{defaultAddress}}" class="address-info">
        <view class="address-top">
          <text class="address-name">{{defaultAddress.name}}</text>
          <text class="address-phone">{{defaultAddress.phone}}</text>
        </view>
        <text class="address-detail">{{defaultAddress.province}}{{defaultAddress.city}}{{defaultAddress.district}}{{defaultAddress.address}}</text>
      </view>
      <view wx:else class="address-empty">
        <text>请添加收货地址</text>
      </view>
      <text class="arrow">></text>
    </view>

    <view class="section">
      <view class="order-item" wx:for="{{items}}" wx:key="skuId">
        <image class="item-img" src="{{item.productImage || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="item-info">
          <text class="item-name">{{item.productName}}</text>
          <text class="item-specs" wx:if="{{item.skuSpecs}}">{{item.skuSpecs}}</text>
          <view class="item-bottom">
            <text class="item-price">¥{{item.price}}</text>
            <text class="item-qty">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section row" bindtap="selectCoupon">
      <text class="row-label">优惠券</text>
      <text class="row-value" wx:if="{{selectedCoupon}}">-¥{{selectedCoupon.discount}}</text>
      <text wx:else class="row-placeholder">选择优惠券</text>
      <text class="arrow">></text>
    </view>

    <view class="section row">
      <text class="row-label">备注</text>
      <input class="row-input" placeholder="选填，备注信息" bindinput="onRemarkInput" />
    </view>

    <view class="section summary">
      <view class="summary-row">
        <text>商品金额</text>
        <text>¥{{totalAmount}}</text>
      </view>
      <view class="summary-row" wx:if="{{discountAmount > 0}}">
        <text>优惠金额</text>
        <text class="discount">-¥{{discountAmount}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="bar-left">
      <text class="bar-label">合计: </text>
      <text class="bar-price">¥{{payAmount}}</text>
    </view>
    <button class="submit-btn" disabled="{{submitting}}" bindtap="submitOrder">
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
