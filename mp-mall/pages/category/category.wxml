<view class="page">
  <view class="search-box">
    <input class="search-input" placeholder="搜索商品" bindinput="onSearchInput" bindconfirm="onSearch" />
  </view>

  <view class="content">
    <scroll-view class="left-menu" scroll-y>
      <view
        class="menu-item {{currentCategory && item.id === currentCategory.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="selectCategory"
        data-item="{{item}}"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="right-content" scroll-y bindscrolltolower="onReachBottom">
      <view class="product-list">
        <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
          <image class="product-img" src="{{item.coverImage || '/images/default-product.png'}}" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="price">¥{{item.standardPrice}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{loading}}" class="loading">加载中...</view>
      <view wx:if="{{!hasMore && products.length > 0}}" class="loading">没有更多了</view>
    </scroll-view>
  </view>
</view>
