.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-box {
  padding: 20rpx;
  background: #fff;
}

.search-input {
  background: #f5f5f5;
  border-radius: 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
}

.content {
  flex: 1;
  display: flex;
}

.left-menu {
  width: 200rpx;
  background: #f8f8f8;
  height: 100%;
}

.menu-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border-left: 4rpx solid transparent;
}

.menu-item.active {
  background: #fff;
  color: #1890ff;
  font-weight: bold;
  border-left-color: #1890ff;
}

.right-content {
  flex: 1;
  padding: 20rpx;
}

.product-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
