.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page-header {
  padding: 20rpx 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: #fff;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.loading {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-tabs {
  background: #fff;
  white-space: nowrap;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 30rpx;
  margin-right: 16rpx;
}

.tab.active {
  background: #1890ff;
  color: #fff;
}

.product-list {
  flex: 1;
  padding: 16rpx;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.activity-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.stock-row {
  display: flex;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
  gap: 20rpx;
}

.action-row {
  margin-top: auto;
  text-align: right;
}

.buy-btn, .group-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #fff;
  border-radius: 30rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 24rpx;
}

.buy-btn {
  background: #ff4d4f;
}

.group-btn {
  background: #722ed1;
}
