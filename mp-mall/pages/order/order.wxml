<view class="page">
  <view class="tabs">
    <view class="tab {{currentTab === index ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="index" bindtap="switchTab" data-index="{{index}}">
      <text>{{item}}</text>
    </view>
  </view>

  <view wx:if="{{loading && orders.length === 0}}" class="loading">加载中...</view>
  <view wx:elif="{{orders.length === 0}}" class="empty">暂无订单</view>

  <scroll-view wx:else class="order-list" scroll-y bindscrolltolower="onReachBottom">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-id">订单号: {{item.orderNo}}</text>
        <text class="order-status {{item.status}}">{{item.displayStatus}}</text>
      </view>

      <view class="order-items" bindtap="goDetail" data-id="{{item.id}}">
        <view class="order-item" wx:for="{{item.displayItems}}" wx:for-item="orderItem" wx:key="id">
          <image class="item-img" src="{{orderItem.productImage || '/images/default-product.png'}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-name">{{orderItem.productName}}</text>
            <text class="item-specs" wx:if="{{orderItem.skuSpecs}}">{{orderItem.skuSpecs}}</text>
            <view class="item-bottom">
              <text class="item-price">¥{{orderItem.price}}</text>
              <text class="item-qty">x{{orderItem.quantity || 1}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-total">共{{item.displayItemCount}}件，合计: <text class="total-price">¥{{item.totalAmount}}</text></text>
      </view>

      <view class="order-actions" wx:if="{{item.status === 'pending'}}">
        <button class="action-btn primary" bindtap="payOrder" data-id="{{item.id}}">立即支付</button>
      </view>
      <view class="order-actions" wx:elif="{{item.status === 'shipped'}}">
        <button class="action-btn" bindtap="confirmOrder" data-id="{{item.id}}">确认收货</button>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!hasMore && orders.length > 0}}" class="loading no-more">没有更多了</view>
  </scroll-view>
</view>
