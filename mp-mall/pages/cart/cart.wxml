<view class="page">
  <view class="cart-header">
    <text class="header-title">购物车</text>
    <text class="header-edit" bindtap="toggleEdit">{{editing ? '完成' : '编辑'}}</text>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{items.length === 0}}" class="empty">
    <text>购物车是空的</text>
    <button class="btn-primary" bindtap="goHome">去逛逛</button>
  </view>

  <scroll-view wx:else class="cart-list" scroll-y>
    <view class="cart-item" wx:for="{{items}}" wx:key="id">
      <view class="item-checkbox {{item.checked ? 'checked' : ''}}" bindtap="toggleSelect" data-id="{{item.id}}">
        <text wx:if="{{item.checked}}">✓</text>
      </view>
      <image class="item-img" src="{{item.productImage || '/images/default-product.png'}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-name">{{item.productName}}</text>
        <text class="item-specs" wx:if="{{item.skuSpecs}}">{{item.skuSpecs}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <view class="qty-control" wx:if="{{!editing}}">
            <text class="qty-btn" bindtap="changeQty" data-id="{{item.id}}" data-type="minus">-</text>
            <text class="qty-value">{{item.quantity}}</text>
            <text class="qty-btn" bindtap="changeQty" data-id="{{item.id}}" data-type="plus">+</text>
          </view>
          <text wx:else class="delete-btn" bindtap="deleteItem" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="cart-bottom" wx:if="{{items.length > 0}}">
    <view class="bottom-left">
      <view class="select-all" bindtap="selectAll">
        <view class="item-checkbox {{allChecked ? 'checked' : ''}}">
          <text wx:if="{{allChecked}}">✓</text>
        </view>
        <text>全选</text>
      </view>
    </view>
    <view class="bottom-center">
      <text class="total-label">合计: </text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="bottom-right">
      <button class="checkout-btn" bindtap="goCheckout">结算({{selectedIds.length}})</button>
    </view>
  </view>
</view>
