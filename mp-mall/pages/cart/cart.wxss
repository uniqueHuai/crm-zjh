.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
}

.header-edit {
  font-size: 26rpx;
  color: #1890ff;
}

.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.empty .btn-primary {
  margin-top: 30rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
}

.cart-list {
  flex: 1;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.item-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.item-checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-specs {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.item-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  font-size: 28rpx;
}

.qty-value {
  width: 70rpx;
  text-align: center;
  font-size: 26rpx;
}

.delete-btn {
  color: #ff4d4f;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
}

.cart-bottom {
  display: flex;
  align-items: center;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 10rpx 30rpx;
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
}

.bottom-left {
  flex-shrink: 0;
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.bottom-center {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.checkout-btn {
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 70rpx;
  line-height: 70rpx;
}
