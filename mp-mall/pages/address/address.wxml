<view class="page">
  <view class="page-header">
    <text>收货地址</text>
    <text class="add-btn" bindtap="addAddress">+ 新增</text>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{addresses.length === 0}}" class="empty">
    <text>暂无收货地址</text>
    <button class="btn-primary" bindtap="addAddress">添加地址</button>
  </view>

  <scroll-view wx:else class="address-list" scroll-y>
    <view class="address-card" wx:for="{{addresses}}" wx:key="id">
      <view class="address-info">
        <view class="address-top">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
        </view>
        <text class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.address}}</text>
      </view>
      <view class="address-actions">
        <view class="action-btn" wx:if="{{!item.isDefault}}" bindtap="setDefault" data-id="{{item.id}}">设为默认</view>
        <view class="action-btn edit" bindtap="editAddress" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </scroll-view>
</view>
