<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crm.customer.mapper.CrmLeadDistributionRuleMapper">

    <select id="selectLogsByRuleId" resultType="com.crm.customer.entity.CrmLeadDistributionLog">
        SELECT * FROM crm_lead_distribution_log
        WHERE rule_id = #{ruleId}
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

</mapper>
